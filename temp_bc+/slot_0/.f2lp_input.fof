s_vehicle(VAR) <- s_truck(VAR).
#hide s_truck/1.
s_vehicle(VAR) <- s_airplane(VAR).
#hide s_airplane/1.
s_thing(VAR) <- s_package(VAR).
#hide s_package/1.
#hide s_location/1.
s_airport(VAR) <- s_location(VAR).
#hide s_airport/1.
#hide s_city/1.

