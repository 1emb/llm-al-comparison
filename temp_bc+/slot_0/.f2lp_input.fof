s_city(o_c0).
s_city(o_c1).
s_airport(o_l0_0).
s_airport(o_l1_0).
s_truck(o_t0).
s_truck(o_t1).
s_airplane(o_a0).
s_airplane(o_a1).
s_package(o_p0).

